# Required for Codex agent execution
OPENAI_API_KEY=sk-...

# Optional runtime location overrides
# SWARM_HOME defaults to auto-discovered runtime root
# SWARM_HOME=~/.openclaw/workspace/swarm
# SWARM_REPOS_FILE=repos.json
# SWARM_DB_PATH=swarm.db
# SWARM_LOGS_DIR=logs

# Optional: Chrome profile for cookie-based auth workflows
CHROME_PROFILE=Default

# Optional: monitor notifications
SWARM_NOTIFY_CHANNEL=discord
SWARM_NOTIFY_TARGET=
SWARM_NOTIFY_REPLY_TO=
